{
  "name": "znode",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run --hot backend/index.ts",
    "output": "bun build ./backend/index.ts --outdir ./dist --target bun --bundle --external drizzle-orm --external drizzle-kit",
    "build": "sh build_frontend.sh",
    "db:push": "bunx drizzle-kit push",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.7",
    "@libsql/client": "^0.17.4",
    "@mastra/core": "^1.49.0",
    "@mastra/libsql": "^1.15.0",
    "@mastra/memory": "^1.22.1",
    "adm-zip": "^0.5.17",
    "ai": "^7.0.15",
    "croner": "^10.0.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "hono-rate-limiter": "^0.5.3"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/bun": "^1.3.11",
    "hono": "^4.12.9",
    "zod": "^4.3.6"
  }
}
